<div class="container after-nav py-3">
  <h1 class="text-center mb-4"> <%= current_user.role.capitalize %> Dashboard</h1>
  <div class="row justify-content-center">
    <!-- Manage Articles Card -->
    <div class="col-md-3 mb-4">
      <div class="card text-center shadow-sm">
        <div class="card-body">
          <i class="fas fa-pencil-square fa-3x text-primary mb-3"></i>
          <h5 class="card-title">Create Article</h5>
          <p class="card-text">Create a new article.</p>
          <%= link_to 'Create New Article', new_article_path, class: 'btn btn-primary' %>
        </div>
      </div>
    </div>
    <!-- Manage Articles Card -->
    <div class="col-md-3 mb-4">
      <div class="card text-center shadow-sm">
        <div class="card-body">
          <i class="fas fa-newspaper fa-3x text-info mb-3"></i>
          <h5 class="card-title">Manage Articles</h5>
          <p class="card-text">Update and delete articles.</p>
          <% if current_user.author? %>
            <%= link_to 'Go to My Articles', user_authored_articles_path(author_id: current_user.id), class: 'btn btn-info' %>
          <% else %>
            <%= link_to 'Go to Articles', user_manage_articles_path, class: 'btn btn-info' %>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Manage Users Card -->
    <% if current_user.admin? %>
      <div class="col-md-3 mb-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-users fa-3x text-success mb-3"></i>
            <h5 class="card-title">Manage Users</h5>
            <p class="card-text">View & update roles of users.</p>
            <%= link_to 'Go to Users', users_path, class: 'btn btn-success' %>
          </div>
        </div>
      </div>
    <% end %>
    <!-- Manage Contests Card -->
    <% if current_user.admin? %>
      <div class="col-md-3 mb-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-trophy fa-3x text-warning mb-3"></i>
            <h5 class="card-title">Manage Contests</h5>
            <p class="card-text">Manage contests.</p>
            <%= link_to 'Go to Contests', contests_path, class: 'btn btn-warning' %>
          </div>
        </div>
      </div>
    <% end %>
    <% if current_user.admin? %>
      <div class="col-md-3 mb-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-chart-line fa-3x text-secondary mb-3"></i>
            <h5 class="card-title">Analytics</h5>
            <p class="card-text">View website analytics.</p>
            <%= link_to 'View Analytics', user_analytics_path, class: 'btn btn-secondary' %>
          </div>
        </div>
      </div>
    <% end %>
    
    <% if current_user.admin? %>
      <div class="col-md-3 mb-4">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <i class="fas fa-images fa-3x text-danger mb-3"></i>
            <h5 class="card-title">Carousel</h5>
            <p class="card-text">Pin or Remove articles from Carousel</p>
            <%= link_to 'Manage Carousel', user_carousel_index_path, class: 'btn btn-danger' %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
