<%# <div class="container-fluid"> %>
<div class="container after-nav py-5 mt-5 flex-grow-1">
  <h1 class="text-center mb-4"> Analytics </h1>
  <div class="row">
    <%= render 'admin/dashboard_sidebar' %>
    <!-- Main Content -->
    <main class="col-md-10 ms-sm-auto px-md-4">
      <div class="row mt-4">
        <!-- Metrics Cards -->
        <div class="col-md-3">
          <div class="card text-white bg-primary mb-3">
            <div class="card-header">Published Articles</div>
            <div class="card-body">
              <h3 class="card-title"><%= @article_metrics[:published] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-success mb-3">
            <div class="card-header">Draft Articles</div>
            <div class="card-body">
              <h3 class="card-title"><%= @article_metrics[:draft] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-secondary mb-3">
            <div class="card-header">Articles Under Review</div>
            <div class="card-body">
              <h3 class="card-title"><%= @article_metrics[:under_review] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-success mb-3">
            <div class="card-header">Approved Articles</div>
            <div class="card-body">
              <h3 class="card-title"><%= @article_metrics[:approved] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-info mb-3">
            <div class="card-header">Active Users</div>
            <div class="card-body">
              <h3 class="card-title"><%= @user_metrics[:active] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-secondary mb-3">
            <div class="card-header">New Users (7 days)</div>
            <div class="card-body">
              <h3 class="card-title"><%= @user_metrics[:new] %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-white bg-danger mb-3">
            <div class="card-header">Deactivated Users</div>
            <div class="card-body">
              <h3 class="card-title"><%= @user_metrics[:deactivated] %></h3>
            </div>
          </div>
        </div>
      </div>
      <!-- Charts Section -->
      <div class="row">
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">User Growth</div>
            <div class="card-body">
              <%# <canvas id="userGrowthChart"></canvas> %>
              <canvas id="userGrowthChart" width="400" height="200"></canvas>

            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">Article Engagement</div>
            <div class="card-body">
              <%# <canvas id="engagementChart"></canvas> %>
              <canvas id="engagementChart" width="400" height="200"></canvas>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script>
  document.addEventListener("turbo:load", function () {
  const ctx1 = document.getElementById("userGrowthChart")?.getContext("2d");
  const ctx2 = document.getElementById("engagementChart")?.getContext("2d");

  if (ctx1) {
    new Chart(ctx1, {
      type: "line",
      data: {
        labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
        datasets: [{
          label: "Users",
          data: [100, 250, 400, 600, 750, 900],
          borderColor: "#007bff",
          fill: false
        }]
      }
    });
  }

  if (ctx2) {
    new Chart(ctx2, {
      type: "bar",
      data: {
        labels: ["Article 1", "Article 2", "Article 3", "Article 4"],
        datasets: [{
          label: "Engagement",
          data: [120, 150, 300, 220],
          backgroundColor: "#28a745"
        }]
      }
    });
  }
});
</script>
