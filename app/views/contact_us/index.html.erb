<div class="container py-5 mt-4 text-black opacity-75">
  <div class="row justify-content-center">
    <div class="col-lg-9">
      <!-- Page Title -->
      <h1 class="display-5 fw-semibold mb-3">We’d love to hear from you!</h1>
      <p class="lead mb-4">
        Whether you’re reaching out to pitch a story, explore advertising opportunities, partner with us,
        or just want to say hello, the Napoleon News team is here for you.
      </p>
      <!-- Who We Are -->
      <h2 class="h5 fw-bold text-uppercase mb-2">Who We Are</h2>
      <p>
        Napoleon News is a media agency headquartered in Texas, USA, with a mission to reshape the
        global narrative about Africa. We tell powerful, positive stories that celebrate the continent’s
        people, cultures, achievements, and ideas. From news and features to digital campaigns and
        storytelling, we amplify Africa's voice on the global stage.
      </p>
      <p>If you believe in purpose-driven storytelling, you're in the right place.</p>
      <!-- Inquiries -->
      <h2 class="h5 fw-bold text-uppercase mt-5 mb-2">For Inquiries</h2>
      <div class="row">
        <div class="col-md-6 mb-4">
          <h6 class="fw-bold">Email</h6>
          <ul class="list-unstyled">
            <li><a href="mailto:editor@napoleonnews.com" class="text-dark text-decoration-underline">editor@napoleonnews.com</a></li>
            <li><a href="mailto:info@napoleonnews.com" class="text-dark text-decoration-underline">info@napoleonnews.com</a></li>
            <li><a href="mailto:advert@napoleonnews.com" class="text-dark text-decoration-underline">advert@napoleonnews.com</a></li>
          </ul>
        </div>
        <div class="col-md-6 mb-4">
          <h6 class="fw-bold">Phone</h6>
          <ul class="list-unstyled">
            <li><a href="tel:+2348064601578" class="text-dark text-decoration-underline">+234 806 460 1578</a></li>
            <li><a href="tel:+2348168783187" class="text-dark text-decoration-underline">+234 816 878 3187</a></li>
            <li><a href="tel:+2349155555294" class="text-dark text-decoration-underline">+234 915 555 5294</a></li>
          </ul>
        </div>
      </div>
      <!-- Social Media -->
      <h2 class="h5 fw-bold text-uppercase mt-4 mb-2">Stay Connected</h2>
      <p>Follow us for the latest stories and updates:</p>
      <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="https://www.linkedin.com/company/napoleon-news-agency" target="_blank" class="btn btn-outline-dark btn-sm">
          <i class="fab fa-linkedin me-1"></i> LinkedIn
        </a>
        <a href="https://www.youtube.com/@Napoleonnewsagency" target="_blank" class="btn btn-outline-secondary btn-sm">
          <i class="fab fa-youtube me-1"></i> YouTube
        </a>
        <a href="https://x.com/napoleonnewsag" target="_blank" class="btn btn-outline-dark btn-sm">
          <i class="fab fa-x-twitter me-1"></i> X
        </a>
        <a href="https://facebook.com/napoleonnewsblog" target="_blank" class="btn btn-outline-primary btn-sm">
          <i class="fab fa-facebook-f me-1"></i> Facebook
        </a>
        <a href="https://tiktok.com/@napoleonnews1" target="_blank" class="btn btn-outline-danger btn-sm">
          <i class="fab fa-tiktok me-1"></i> TikTok
        </a>
      </div>
      <h2 class="h5 fw-bold text-uppercase mt-5 mb-2">Send Us a Message</h2>
      <div class="card shadow-sm border-1 mb-4">
        <div class="card-body px-4 py-5">
          <%= form_with url: contact_us_path,
                  method: :post,
                  local: true,
                  class: "needs-validation",
                  novalidate: true do |f| %>
            <div class="row g-3">
              <!-- Name -->
              <div class="col-md-6">
                <label class="form-label fw-semibold" for="contact_name">Your Name</label>
                <%= f.text_field :name,
                           id: "contact_name",
                           class: "form-control",
                           placeholder: "Jane Doe",
                           required: true %>
                <div class="invalid-feedback">Please enter your name.</div>
              </div>
              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold" for="contact_email">Your Email</label>
                <%= f.email_field :email,
                            id: "contact_email",
                            class: "form-control",
                            placeholder: "you@example.com",
                            required: true %>
                <div class="invalid-feedback">Please provide a valid email.</div>
              </div>
              <!-- Message -->
              <div class="col-12">
                <label class="form-label fw-semibold" for="contact_message">Message</label>
                <%= f.text_area :message,
                          id: "contact_message",
                          class: "form-control",
                          rows: 6,
                          placeholder: "How can we help you?",
                          required: true %>
                <div class="invalid-feedback">Message can’t be empty.</div>
              </div>
              <!-- Submit -->
              <div class="col-12 text-end">
                <%= f.submit "Send Message",
                       class: "btn btn-primary px-4" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <!-- Tiny helper to enable Bootstrap’s validation feedback -->
      <script>
        (function () {
          const forms = document.querySelectorAll('.needs-validation');
          Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
              if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
              }
              form.classList.add('was-validated');
            }, false);
          });
        })();
      </script>
    </div>
  </div>
