<style>
  /* New */
   .contest-header {
      /* background: linear-gradient(135deg, #1e1e2f, #a27ea8); */
      color: white;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0px 6px 12px rgba(0, 0, 0, 0.3);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .contest-header h1 {
      font-size: 2.8rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-shadow: 2px 2px 8px rgba(255, 255, 255, 0.2);
    }

    .contest-header h2 {
      font-size: 1.6rem;
      font-weight: 600;
      opacity: 0.9;
    }
  /* End */


    /* Container for the floating particles */
    .contest-container {
      position: relative;
      width: 100%;
      /* height: 70%%; Adjust height as needed */
      background-color:rgb(7, 37, 97);
      
      /* Dark background to make particles pop */
      overflow: hidden; /* Prevents particles from overflowing */
    }

    /* Particle styling */
    .particle {
      position: absolute;
      border-radius: 50%;
      background-color: rgba(255, 255, 255, 0.7);
      animation: float 8s infinite ease-in-out;
      opacity: 0.8;
    }

    body {
      /* background-color:rgb(0, 45, 136); Dark background to make particles pop */
    }

    /* Keyframes for particle movement */
    @keyframes float {
      0% {
        transform: translateY(0) translateX(0);
        opacity: 0.8;
      }
      25% {
        transform: translateY(-30px) translateX(30px);
        opacity: 1;
      }
      50% {
        transform: translateY(0) translateX(60px);
        opacity: 0.8;
      }
      75% {
        transform: translateY(20px) translateX(-40px);
        opacity: 1;
      }
      100% {
        transform: translateY(0) translateX(0);
        opacity: 0.8;
      }
    }

    .footer {
      display: none;
    }
</style>
<script>
  // Set the date we're counting down to
  var countDownDate = new Date("2025-02-28 23:59:59").getTime();


  // Update the countdown every 1 second
  var x = setInterval(function() {
    // Get current time
    var now = new Date().getTime();

    // Find the time difference
    var distance = countDownDate - now;

    // Calculate time components
    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    // Display the result in the element with id="countdown-timer"
    document.getElementById("countdown-timer").innerHTML = days + "d " + hours + "h "
    + minutes + "m " + seconds + "s ";

    // If the countdown is over
    if (distance < 0) {
      clearInterval(x);
      document.getElementById("countdown-timer").innerHTML = "EXPIRED";
    }
  }, 1000);
</script>
