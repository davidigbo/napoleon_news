<!DOCTYPE html>
<html>
  <head>
    <%= display_meta_tags site: 'Napoleon News' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" alt="napoleon-news-logo">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" alt="napoleon-news-logo">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" alt="napoleon-news-logo">
    <link rel="manifest" href="/manifest.json">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="d-flex flex-column min-vh-100 pt-4" data-controller="flash-notifications">
    <div class="container-fluid p-0 flex-grow-1 mb-5 contest-container">
      <%= render 'layouts/nav' %>
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == 'alert' ? 'danger' : type == 'notice' ? 'success' : type %> alert-dismissible fade show after-nav" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <%= yield %>
      <div class="particle" style="top: 10%; left: 10%; width: 10px; height: 10px;"></div>
      <div class="particle" style="top: 20%; left: 25%; width: 15px; height: 15px;"></div>
      <div class="particle" style="top: 30%; left: 50%; width: 8px; height: 8px;"></div>
      <div class="particle" style="top: 40%; left: 70%; width: 12px; height: 12px;"></div>
      <div class="particle" style="top: 50%; left: 80%; width: 18px; height: 18px;"></div>
      <div class="particle" style="top: 60%; left: 40%; width: 10px; height: 10px;"></div>
      <div class="particle" style="top: 70%; left: 60%; width: 14px; height: 14px;"></div>
      <div class="particle" style="top: 80%; left: 90%; width: 16px; height: 16px;"></div>
      <div class="particle" style="top: 90%; left: 50%; width: 9px; height: 9px;"></div>
      <div class="particle" style="top: 10%; left: 10%; width: 10px; height: 10px;"></div>
      <div class="particle" style="top: 20%; left: 25%; width: 15px; height: 15px;"></div>
      <div class="particle" style="top: 30%; left: 50%; width: 8px; height: 8px;"></div>
      <div class="particle" style="top: 40%; left: 70%; width: 12px; height: 12px;"></div>
      <div class="particle" style="top: 50%; left: 80%; width: 18px; height: 18px;"></div>
      <div class="particle" style="top: 60%; left: 40%; width: 10px; height: 10px;"></div>
      <div class="particle" style="top: 70%; left: 60%; width: 14px; height: 14px;"></div>
      <div class="particle" style="top: 80%; left: 90%; width: 16px; height: 16px;"></div>
      <div class="particle" style="top: 90%; left: 50%; width: 9px; height: 9px;"></div>
    </div>
    <%= render 'layouts/footer' %>
  </body>
</html>
