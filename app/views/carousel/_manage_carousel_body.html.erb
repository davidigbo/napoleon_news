<div class=row>
  <%= form_with url: user_carousel_index_path(current_user), method: :patch do |form| %>
    <div class="mb-3 text-end">
      <%= form.submit "Save Changes", class: "btn btn-primary" %>
    </div>
    <div class="row g-3">
      <% @articles.each do |article| %>
        <div class="col-12 col-md-6 col-lg-4 d-flex">
          <div class="card shadow-sm w-100 d-flex flex-column">
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="card-title"><%= article.title %></h5>
                <%= check_box_tag 'article_ids[]', 
                                    article.id, 
                                    @carousel_articles.include?(article), 
                                    id: "article_#{article.id}",
                                    class: 'carousel-checkbox form-check-input',
                                    data: { max_allowed: 7 } %>
              </div>
              <p class="card-text text-muted">
                <strong>Published At:</strong> <%= article.created_at.strftime("%B %d, %Y") %><br>
                <strong>Categories:</strong>
                <% article.categories.where.not(name: 'Carousel').each do |category| %>
                  <span class="badge bg-secondary"><%= category.name %></span>
                <% end %>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>