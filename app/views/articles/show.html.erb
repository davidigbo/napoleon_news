<div class="container article-container after-nav py-3">
  <div class="row">
    <div class="col-md-8 border rounded-1 p-3 shadow bg-body-tertiary">
      <!-- Article Header -->
      <div class="row">
        <div class="col-12">
          <h2><%= @article.title %></h2>
          <p class="text-muted">
            <%= @article.anonymize ? '' : raw("By <span class='fw-bold'>#{@article.author.first_name} #{@article.author.last_name}</span> • ") %>
            <span><i class="fa fa-calendar" aria-hidden="true"></i></span>
            <span class="timestamp" data-utc="<%= @article.published_at&.iso8601 %>"></span>
          </p>
        </div>
      </div>
      <div class="row border-bottom mb-2">
        <p class="fst-italic fw-semibold"><%= @article.description %></p>
      </div>
      <!-- Tags -->
      <div class="row">
        <div class="col-6 mb-3">
          <% @article.tags.each_with_index do |tag, idx|%>
            <span class="badge <%= tag_classes[idx] %>" ><%= tag.name.capitalize  %></span>
          <% end %>
        </div>
        <div class="col-6 mb-3 text-end pe-3">
          <i class="fas fa-share-alt fa-lg me-3"></i>
          <!-- Social Media Icons -->
          <!-- Facebook Share -->
          <a href="https://www.facebook.com/sharer/sharer.php?u=<%= CGI.escape(article_url(@article)) %>" class="text-decoration-none text-primary me-3" target="_blank" rel="noopener noreferrer">
            <i class="fab fa-facebook fa-lg"></i>
          </a>
          <!-- Twitter Share -->
          <a href="https://twitter.com/intent/tweet?url=<%= CGI.escape(article_url(@article)) %>&text=<%= CGI.escape(@article.title) %>" class="text-decoration-none text-dark me-3" target="_blank" rel="noopener noreferrer">
            <i class="fab fa-twitter fa-lg"></i>
          </a>
          <!-- LinkedIn Share -->
          <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= CGI.escape(article_url(@article)) %>" class="text-decoration-none text-secondary" target="_blank" rel="noopener noreferrer">
            <i class="fab fa-linkedin fa-lg"></i>
          </a>
        </div>
        <!-- Article Body -->
        <div class="row">
          <div class="col-12">
            <%= @article_body %>
            <%#= render_action_text_content(@article_body) %>
            <%# <%= render_with_alt_text(@article_body) %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
      </div>
      <!-- Comments Section -->
      <% if @article.published?  %>
        <div class="row mt-4">
          <div class="col-12">
            <h4 class="border-bottom pb-2">Comments</h4>
            <!-- Display Comments -->
            <div id="comments">
              <% @comments.each do |comment| %>
                <div class="border rounded-1 p-3 mb-2 bg-light">
                  <p class="mb-1 fw-bold"><%= comment.author.first_name %> <%= comment.author.last_name %></p>
                  <p class="mb-1"><%= comment.body %></p>
                  <p class="text-muted small"><i class="fa fa-clock"></i> <%= time_ago_in_words(comment.created_at) %> ago</p>
                  <!-- Delete button (visible only to admins) -->
                  <% if current_user&.admin? %>
                    <%= button_to "Delete", article_comment_path(@article, comment), 
                                method: :delete, 
                                data: { confirm: "Are you sure you want to delete this comment?" }, 
                                class: "btn btn-sm btn-danger" %>
                  <% end %>
                </div>
              <% end %>
            </div>
            <!-- Comment Form -->
            <% if user_signed_in? %>
              <div class="mt-3">
                <%= form_with(model: [@article, Comment.new], url: article_comments_path(@article), local: true) do |f| %>
                  <div class="mb-3">
                    <%= f.text_area :body, class: "form-control", placeholder: "Write a comment...", rows: 3 %>
                    <%= f.hidden_field :comment_type, value: 'reader_comment' %>
                  </div>
                  <div>
                    <%= f.submit "Post Comment", class: "btn btn-primary" %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mt-2">You must be <a href="<%= new_user_session_path %>">logged in</a> to comment.</p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <!-- Read More from This Category -->
    <% if @related_articles.any? %>
      <div class="row mt-5">
        <div class="col-12">
          <h4 class="border-bottom pb-2">Read more articles like this </h4>
        </div>
        <div class="row mt-5">
          <% @related_articles.each do |related_article| %>
            <div class="col-md-4 d-flex">
              <div class="card shadow-sm d-flex flex-column w-100">
                <%= link_to article_path(related_article), class: "text-decoration-none text-dark h-100 d-flex flex-column" do %>
                  <% if related_article.image.present? %>
                    <%= image_tag related_article.image.variant(resize_to_fill: [300, 200]), class: "card-img-top", alt: related_article.title %>
                  <% end %>
                  <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold"><%= truncate(related_article.title, length: 50) %></h6>
                    <p class="card-text text-muted small mt-auto">
                      <i class="fa fa-calendar"></i> <%= related_article.published_at.strftime("%b %d, %Y") %>
                    </p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>