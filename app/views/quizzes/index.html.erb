<h1>Welcome to the Quiz</h1>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    setTimeout(() => {
      let quizPopup = document.getElementById("quiz-popup");
      if (quizPopup) {
        quizPopup.style.display = "block";
      }
    }, 5000);
  });

  function closePopup() {
    document.getElementById("quiz-popup").style.display = "none";
  }
</script>

<div id="quiz-popup" style="display: none; position: fixed; top: 20%; left: 30%; width: 40%; background: white; padding: 20px; box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);">
  <h2>Take a Quiz</h2>
  <% if @quiz %>
    <p><%= @quiz.title %></p>
    <a href="<%= quiz_path(@quiz) %>">Start Quiz</a>
  <% else %>
    <p>No quizzes available</p>
  <% end %>
  <button onclick="closePopup()">Close</button>
</div>
