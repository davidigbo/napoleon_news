<div class="container after-nav py-3">
  <%= render 'layouts/contest_header' %>
  <!-- Link to the leaderboard -->
  <div class="mt-4 text-center">
    <%= link_to "View the Leaderboard", contest_leaderboards_path(@contest), class: "btn btn-outline-warning" %>
  </div>
  <h2 class="text-warning">Enter the Contest</h2>
  <%= form_with model: @contestant, url: contest_contestants_path, html: { class: "needs-validation text-white", enctype: "multipart/form-data", novalidate: true } do |f| %>
    <div class="mb-3">
      <%= f.label :stage_name, "Stage Name", class: "form-label" %>
      <%= f.text_field :stage_name, class: "form-control", required: true %>
    </div>
    <div class="mb-3">
      <%= f.label :description, "About Me", class: "form-label" %>
      <%= f.text_area :description,  maxlength: 250, class: "form-control", rows: 3, required: true %>
      <small class="form-text text-white">Maximum 250 characters</small>
    </div>
    <div class="mb-3">
      <%= f.label :image, "Upload Picture", class: "form-label" %>
      <%= f.file_field :image, class: "form-control", required: true %>
    </div>
    <%= f.submit "Submit", class: "btn btn-warning" %>
  <% end %>
</div>
