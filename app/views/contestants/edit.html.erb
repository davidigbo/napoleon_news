<div class="container after-nav py-3">
  <%= render 'layouts/contest_header' %>
  <div class="mt-4 text-center">
    <%= link_to "View the Leaderboard", mbgn_leaderboard_path, class: "btn btn-outline-warning" %>
  </div>
  <h2 class="text-white">Edit Contestant</h2>
  <%= form_with(model: @contestant, url: contest_contestant_path(@contest, @contestant), local: true, class: 'text-white') do |f| %>
    <% if @contestant.errors.any? %>
      <div id="error_explanation" class="alert alert-danger">
        <h4><%= pluralize(@contestant.errors.count, "error") %> prohibited this contestant from being saved:</h4>
        <ul>
          <% @contestant.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div class="mb-3">
      <%= f.label :stage_name, "Stage Name", class: "form-label" %>
      <%= f.text_field :stage_name, class: "form-control", required: true %>
    </div>
    <div class="mb-3">
      <%= f.label :description, "About Me", class: "form-label" %>
      <%= f.text_area :description,  maxlength: 250, class: "form-control", rows: 3, required: true %>
      <small class="form-text text-white">Maximum 250 characters</small>
    </div>
    <div class="mb-3">
      <%= f.label :image, "Upload Picture", class: "form-label" %>
      <%= f.file_field :image, class: "form-control", required: true %>
    </div>
    <%= f.submit "Submit", class: "btn btn-warning" %>
  <% end %>
</div>
