<div class="container after-nav py-3 text-center">
  <h2><%= @contestant.stage_name %></h2>

  <% if @contestant.image.attached? %>
    <%= image_tag @contestant.image.variant(resize_to_limit: [500, 500]), class: "img-fluid rounded", alt: "Contestant Image" %>
  <% else %>
    <p>No image available</p>
  <% end %>

  <p class="mt-3"><%= @contestant.description %></p>

  <div>
    <%= button_tag "Vote", class: "btn btn-success" %>
    <%= button_tag "Comment", class: "btn btn-info" %>

    <div class="mt-3">
      <%= link_to "Share on Facebook", "#", class: "btn btn-primary" %>
      <%= link_to "Share on Twitter", "#", class: "btn btn-info" %>
      <%= link_to "Share on WhatsApp", "#", class: "btn btn-success" %>
    </div>
  </div>
</div>
