<div class="container-fluid after-nav py-4" style="background: linear-gradient(135deg, #000000, #2b0011, #5a001a, #b8860b);">
  <div class="card shadow-lg border-0 p-4 text-center text-light" style="background: linear-gradient(135deg, #000000, #2b0011, #5a001a, #b8860b);">
    <div class="text-center mb-3">
      <i class="fas fa-trophy text-white display-4"></i> <!-- Trophy Icon -->
    </div>
    <h2 class="mb-3 fw-bold">Leaderboard</h2>

    <!-- Enter Contest Button -->
    <div class="my-4 text-center">
      <%= link_to "Enter the Contest", mbgn_path, class: "btn btn-warning btn-lg fw-bold px-4" %>
    </div>
    
    <!-- Leaderboard Stats -->
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card shadow-lg border-0 p-3 text-center text-dark bg-white">
          <div class="display-5 fw-bold"><%= @contest.contestants.approved.count %></div>
          <p class="text-uppercase text-muted">Total Contestants</p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-lg border-0 p-3 text-center text-dark bg-white">
          <div class="display-5 fw-bold"><%= @total_votes %></div>
          <p class="text-uppercase text-muted">Total Votes</p>
        </div>
      </div>
    </div>
    
    <!-- Leaderboard -->
    <div class="card shadow-lg border-0 p-4 bg-light">
      <h2 class="text-center mb-4 text-dark">Leaderboard</h2>

      <!-- Contestant Rows -->
      <div class="list-group">
        <% @contestants.each_with_index do |contestant, index| %>
          <div class="list-group-item shadow-sm mb-3 bg-white rounded p-3">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
              
              <!-- Rank -->
              <div class="text-dark fw-bold text-center fs-4 w-100 w-md-10">#<%= index + 1 %></div>

              <!-- Contestant: Image + Name -->
              <div class="d-flex flex-column flex-md-row align-items-center w-100 w-md-35 text-center text-md-start">
                <div class="me-md-3 mx-auto mx-md-0" style="width: 60px; height: 60px;">
                  <%= link_to mbgn_contestant_path(contestant) do %>
                    <% if contestant.image.attached? %>
                      <%= image_tag contestant.image.variant(resize_to_limit: [60, 60]), 
                            class: "img-fluid rounded-circle border border-2 border-primary shadow-sm contestant-img", 
                            alt: contestant.stage_name %>
                    <% else %>
                      <div class="rounded-circle border border-2 border-primary shadow-sm d-flex align-items-center justify-content-center bg-light" style="width: 60px; height: 60px;">
                        <i class="fas fa-user text-muted"></i>
                      </div>
                    <% end %>
                  <% end %>
                </div>
                <div>
                  <%= link_to contestant.stage_name, mbgn_contestant_path(contestant), class: "contestant-link fw-bold text-dark text-decoration-none" %>
                </div>
              </div>

              <!-- Votes & Percentage (Stacked on mobile) -->
              <div class="d-flex flex-column flex-md-row align-items-center w-100 w-md-30">
                <div class="fw-bold text-success text-center w-100 w-md-50">
                  <%= contestant.votes.count %> Votes
                </div>
                <div class="fw-bold text-muted text-center w-100 w-md-50">
                  <%= number_to_percentage((contestant.votes.count.to_f / @total_votes) * 100, precision: 1) %>
                </div>
              </div>

            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  /* Contestant link hover effect */
  .contestant-link:hover {
    color: #b8860b !important;
    text-decoration: underline !important;
  }

  /* Image hover effect */
  .contestant-img {
    transition: transform 0.3s ease-in-out;
  }

  .contestant-img:hover {
    transform: scale(1.2);
  }

  /* Responsive width utility classes */
  @media (min-width: 768px) {
    .w-md-10 { width: 10%; }
    .w-md-35 { width: 35%; }
    .w-md-30 { width: 30%; }
    .w-md-50 { width: 50%; }
  }
</style>
