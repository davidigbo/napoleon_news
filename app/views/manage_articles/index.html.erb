<div class="container after-nav py-5 mt-5">
  <%= render "layouts/back_button" %>
  <div class="text-center">
    <h1>Manage Articles</h1>
    <div class="mt-4 row">
      <div class="col-md-3">
        <%= link_to 'Draft Articles', draft_user_manage_articles_path, class: 'btn btn-lg btn-primary me-3 mb-2' %>
      </div>
      <div class="col-md-3">
        <%= link_to 'Under Review Articles', under_review_user_manage_articles_path, class: 'btn btn-lg btn-secondary me-3 mb-2' %>
      </div>
      <div class="col-md-3">
        <%= link_to 'Published Articles', published_user_manage_articles_path, class: 'btn btn-lg btn-success me-3 mb-2' %>
      </div>
      <div class="col-md-3">
        <%= link_to 'Approved Articles', approved_user_manage_articles_path, class: 'btn btn-lg btn-warning mb-2' %>
      </div>
    </div>
  </div>
</div>
