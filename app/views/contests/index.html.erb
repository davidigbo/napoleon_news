<div class="container after-nav py-5">
  <h1 class="text-center mb-4">Manage Contests</h1>
  <div class="row">
    <%= render 'admin/dashboard_sidebar' %>
    <main class="col-md-10 ms-sm-auto px-md-4">
      <!-- Contest List -->
      <div class="row g-3">
        <% @contests.each do |contest| %>
          <div class="col-12 col-md-6 col-lg-4 d-flex">
            <div class="card shadow-sm w-100 d-flex flex-column">
              <div class="card-body d-flex flex-column">
                <h5 class="card-title">
                  <%= link_to contest.name, '#', class: 'text-dark link-offset-2 link-offset-3-hover' %>
                </h5>
                <p class="card-text mb-1">
                  <%# <strong>Start Date:</strong> <%= contest.start_date %><br>
                  <%# <strong>End Date:</strong> <%= contest.end_date %><br>
                  <strong>Status:</strong> <%= contest.status.capitalize %>
                </p>
                <div class="mt-auto">
                  <div class="d-flex flex-column flex-sm-row gap-2">
                    <!-- View Leaderboard -->
                    <%= link_to 'View Leaderboard', mbgn_leaderboard_path, class: 'btn btn-sm btn-primary' %>
                    <!-- Manage Contestants -->
                    <%= link_to 'Manage Contestants', mbgn_contestants_path, class: 'btn btn-sm btn-warning' %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </main>
  </div>
  <%# <%= paginate @contests, param_name: :contest_page, anchor: 'contest' %>
</div>
